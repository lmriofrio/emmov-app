<!doctype html>
<html lang="es" data-bs-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <title>Solicitud pdf</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.46.0/tabler-icons.min.css">
    <link rel="stylesheet" href="../../public/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.js"
        integrity="sha256-H+K7U5CnXl1h5ywQfKtSj8PCmoN9aaq30gDh27Xc0jk=" crossorigin="anonymous"></script>
    <script src="/js/activar-items-navbar.js"></script>

    <script src="/js/main.js"></script>
    <style>
        @page {
            size: A4;
            margin: 5mm;
        }

        body {
            width: 210mm;
            height: 297mm;
            margin: 0;
            display: flex;
            align-items: start;
            justify-content: center;
            background: white;
        }

        @media print {

            /* Forzar la impresión de colores de fondo y sombras */
            .card,
            .bg-blue-sri,
            .badge,
            .text-bg-primary {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
                color-adjust: exact !important;
            }

            /* Asegurar que el fondo azul sea visible */
            .bg-blue-sri {
                background-color: #004595 !important;
                /* Ajusta al azul exacto que usas */
                color: white !important;
            }

            /* Asegurar que la tarjeta interna blanca se mantenga blanca y no transparente */
            #cosultaSRI {
                background-color: white !important;
                border: 1px solid #dee2e6 !important;
                /* Un borde fino ayuda en la impresión */
            }

            /* Evitar que el texto blanco desaparezca si el fondo falla */
            .text-white {
                color: white !important;
            }
        }
    </style>




</head>

<body>


