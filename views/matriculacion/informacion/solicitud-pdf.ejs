                                                    <% titulosCredito.forEach((titulo, index)=> { %>

                                                        <tr>

                                                            <td class="text-center fs-1">
                                                                <%= index + 1 %>
                                                            </td>

                                                            <td class="fs-1">
                                                                <%= titulo.nombre_concepto %>
                                                            </td>

                                                            <td class="text-center fs-1">
                                                                <%= titulo.cantidad_concepto %>
                                                            </td>

                                                            <td class="text-end fs-1">
                                                                $ <%= Number(titulo.valor_unitario_concepto).toFixed(2)
                                                                    %>
                                                            </td>

                                                            <td class="text-end fs-1">
                                                                $ <%= Number(titulo.subtotal_concepto).toFixed(2) %>
                                                            </td>

                                                        </tr>

                                                        <% total +=Number(titulo.subtotal_concepto); %>

                                                            <% }) %>

                                            </tbody>

                                            <tfoot>

                                                <tr>

                                                    <th colspan="4" class="text-end fs-1">TOTAL $</th>

                                                    <th class="text-end fs-1">
                                                        <%= total.toFixed(2) %>
                                                    </th>

                                                </tr>

                                            </tfoot>

                                        </table>


                                    </div>
                                </div>




                            </div>

                            <div class="card-body d-flex p-1 ms-1">

                                <div class="mb-0 col-12">
                                    <div class="card-body p-1">

                                        <h6 class="fw-normal mb-1 mt-1 text-start text-black">Por la atención al
                                            presente, le
                                            expreso
                                            mis mas sinceros agradecimientos</h6>


                                        <h6 class="fw-normal mb-0 mt-3 text-start text-black pb-2 d-none">Atentamente.
                                        </h6>
                                        <br>
                                        <br>

                                        <div class="firma-contenedor">
                                            <div class="col-6 d-flex justify-content-center align-items-center">
                                                <img src="/archivos/<%= archivoFirma %>" style="width: 150px;" alt="">
                                            </div>
                                            <div class="col-6"></div>


                                        </div>
                                        <ul class="list-group list-group-flush  fs-2 mt-0 pt-2">

                                            <div class="d-flex">
                                                <li
                                                    class="list-group-item col-6  px-2 py-0 d-flex justify-content-start align-items-center">
                                                    <div class="row w-100 text-center">
                                                        <div class="col">
                                                            <strong>----------------------------------</strong>
                                                        </div>
                                                    </div>
                                                </li>
                                                <li
                                                    class="list-group-item col-6  px-2 py-0 d-flex justify-content-start align-items-center">
                                                    <div class="row w-100 text-center">
                                                        <div class="col">
                                                            <strong>----------------------------------</strong>
                                                        </div>
                                                    </div>
                                                </li>
                                            </div>


                                            <div class="d-flex ">
                                                <li class="list-group-item col-6 px-2 py-0">
                                                    <div class="row">
                                                        <div class="col">
                                                            <p
                                                                class="form-control-plaintext p-0 text-center text-uppercase fw-semibold">
                                                                <%= tramite.nombre_funcionario_INFORMACION %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </li>
                                                <li class="list-group-item col-6  px-2 py-0">
                                                    <div class="row">
                                                        <div class="col">
                                                            <p
                                                                class="form-control-plaintext mb-0 p-0 text-center text-uppercase fw-semibold">
                                                                <%= tramite.nombre_usuario %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                </li>
                                            </div>

                                            <div class="d-flex ">
                                                <li class="list-group-item col-6 px-2 py-0">
                                                    <div class="row">
                                                        <div class="col">
                                                            <p class="form-control-plaintext p-0 text-center">
                                                                FUNCIONARIO
                                                            </p>
                                                        </div>
                                                    </div>
                                                </li>
                                                <li class="list-group-item col-6  px-2 py-0">
                                                    <div class="row">
                                                        <div class="col">
                                                            <p class="form-control-plaintext mb-0 p-0 text-center">
                                                                SOLICITANTE
                                                            </p>
                                                        </div>
                                                    </div>
                                                </li>
                                            </div>
                                        </ul>

                                    </div>
                                </div>

                            </div>


                            <div class="card-body d-flex p-1 ms-1" id="" name="">
                                <div class="col-12 mb-0">
                                    <div class="card-body p-1 rounded d-flex align-items-center">
                                        <i class="ti ti-exclamation-circle me-2 fs-5"></i>
                                        <div class="d-flex justify-content-left w-100">
                                            <h6 class="fw-normal mb-0 text-black me-2" id="">OBSERVACIÓN:</h6>
                                            <h6 class="fw-semibold mb-0 text-start" id="">
                                                <%= tramite.observaciones_INFORMACION %>
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>


                            <div class="card-body d-flex p-1 d-none ms-1" id="deudas_SRI" name="deudas_SRI">
                                <div class="col-12 mb-0">
                                    <div class="card-body p-1 rounded d-flex align-items-center">
                                        <i class="ti ti-exclamation-circle me-2 fs-5"></i>
                                        <div class="d-flex justify-content-left w-100">
                                            <h6 class="fw-normal mb-0 text-black me-2 d-none"
                                                data-informacion="<%= tramite.informacion_SRI %>">
                                            </h6>
                                            <h6 class="fw-normal mb-0 text-black me-2" id="mensaje_SRI">El vehiculo
                                                tiene deudas
                                                en el
                                                SRI:</h6>
                                            <h6 class="fw-semibold mb-0 text-start" id="deuda_total_SRI"></h6>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card-body d-flex p-1 d-none ms-1" id="no_deudas_SRI" name="no_deudas_SRI">
                                <div class="col-12 mb-0">
                                    <div class="card-body p-1 rounded d-flex align-items-center">
                                        <i class="ti ti-exclamation-circle me-2 fs-5"></i>
                                        <div class="d-flex justify-content-left w-100">
                                            <h6 class="fw-normal mb-0 text-black me-2">Sin datos
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>


                            <script>
                                document.addEventListener('DOMContentLoaded', () => {

                                    const informacionSRI = '<%- tramite.informacion_SRI || "" %>';
                                    const totalSRI = '<%- tramite.total_SRI       || "" %>';
                                    const deudasCard = document.getElementById('deudas_SRI')
                                    const sinDeudasCard = document.getElementById('no_deudas_SRI');
                                    const totalH6 = document.getElementById('deuda_total_SRI');
                                    const infoVacia = !informacionSRI || informacionSRI.trim() === '';
                                    const totalConValor = totalSRI && totalSRI.toString().trim() !== '' && Number(totalSRI) > 0;

                                    if (infoVacia && totalConValor) {
                                        deudasCard.classList.remove('d-none');
                                        totalH6.textContent = totalSRI;
                                    } else {
                                        sinDeudasCard.classList.remove('d-none');
                                    }
                                });
                            </script>

                            <div class="card-body d-flex p-1 ms-1 d-none" id="no_deudas_SRI22" name="no_deudas_SRI22">
                                <div class="col-12 mb-0">
                                    <div class="card-body p-1 rounded d-flex align-items-center">
                                        <i class="ti ti-exclamation-circle me-2 fs-5"></i>
                                        <div class="d-flex justify-content-left w-100">
                                            <h6 class="fw-normal mb-0 text-black me-2 fs-2">
                                            </h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-3">


                            <% if (datosSRI.estado==='CON_DEUDAS' || datosSRI.estado==='SIN_DEUDAS' ) { %>

                                <div class="col-12 fs-2 ms-1 shadow-none" id="contentConSRI">
                                    <div class="card bg-blue-sri border-0 w-100 shadow-none">
                                        <div class="card-body p-2 pb-0 shadow-none">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <div>
                                                    <h4 class="fw-semibold mb-0 text-white card-title">SRI</h4>
                                                    <p class="fs-3 mb-0 text-white">Valores a pagar</p>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <img src="/images/sri_logo.jpg"
                                                        class="rounded-circle border border-2 border-white"
                                                        style="width: 45px; height: 45px; object-fit: cover;">
                                                </div>
                                            </div>

                                            <div class="py-2"></div>
                                        </div>

                                        <div class="card mx-2 mb-2 mt-n4 shadow-none" id="cosultaSRI">
                                            <div class="card-body p-2">
                                                <div class="row mb-1">
                                                    <div class="col-12">
                                                        <div class="d-flex gap-2 mb-0">
                                                            <strong
                                                                class="form-label fw-semibold mb-0 col-5 fs-2">Placa:</strong>
                                                            <div class="form-label mb-0 fw-normal fs-2">
                                                                <%= tramite.placa %>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex gap-2 mb-0">
                                                            <strong
                                                                class="form-label fw-semibold mb-0 col-5 fs-2">Marca:</strong>
                                                            <div class="form-label mb-0 fw-normal fs-2">
                                                                <%= tramite.marca %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-12 py-0 <%= datosSRI.estado === 'SIN_DEUDAS' ? '' : 'd-none' %>"
                                                    id="sinDeudasSRI">
                                                    <div class="text-center">
                                                        <img src="/images/ic_tick.png" class="rounded-circle mb-2"
                                                            width="50" height="50">
                                                        <div class="form-label fw-normal text-center fs-2 pt-2">
                                                            <%= datosSRI.mensajeInformacion %>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-12 <%= datosSRI.estado === 'CON_DEUDAS' ? '' : 'd-none' %>"
                                                    id="DeudasSRI">
                                                    <p class="text-muted small fw-normal mb-2">Detalle de rubros:</p>
                                                    <table class="table table-sm table-borderless mb-2">
                                                        <tbody>
                                                            <% datosSRI.filas.forEach(function(fila) { %>
                                                                <tr class="border-bottom border-light">
                                                                    <td
                                                                        class="text-start fs-1 text-uppercase text-muted py-2">
                                                                        <%= fila.descripcion_rubro %>
                                                                    </td>
                                                                    <td class="text-end fw-semibold fs-2 py-2">
                                                                        $<%= parseFloat(fila.valor).toFixed(2) %>
                                                                    </td>
                                                                </tr>
                                                                <% }); %>
                                                        </tbody>
                                                    </table>

                                                    <div class="d-flex justify-content-between align-items-center p-0">
                                                        <span class="text-muted small fw-normal fs-1">Total a
                                                            pagar:</span>
                                                        <span class="badge bg-danger fs-2" id="total">
                                                            USD $<%= datosSRI.totalPagar %>
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="mt-0 pt-0">
                                                    <p class="mb-0 text-center text-muted" style="font-size: 0.7rem;">
                                                        Consulta realizada en: <br>
                                                        <span class="">https://srienlinea.sri.gob.ec</span>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <% } else { %>
                                    <div class="col-12 fs-2 ms-1 shadow-none" id="noDisponibleSRI">
                                        <div class="card shadow-none">
                                            <div class="card-body p-2 shadow-none">
                                                <div class="card-body">
                                                    <div class="d-flex align-items-center">
                                                        <span class="flex-shrink-0">
                                                            <i class="ti ti-x text-red display-6"></i>
                                                        </span>
                                                        <div class="ms-4">
                                                            <span class="text-subtitle fs-2 mt-1">Servicio no
                                                                disponible</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>

                                        <div class="pt-2 rounded text-center text-black card border shadow-none ms-1">
                                            <div class="d-flex flex-column align-items-center justify-content-center">
                                                <span class="text-uppercase fw-normal fs-3 border-bottom">Abril /
                                                    dígito</span>
                                                <span class="fw-bold fs-12 text-black">3</span>
                                            </div>
                                        </div>
                        </div>
                    </div>
                </div>
            </div>


        </div>

    </div>




</body>

</html>