<!doctype html>
<html lang="es" data-bs-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <title>Home</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.46.0/tabler-icons.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.js"
        integrity="sha256-H+K7U5CnXl1h5ywQfKtSj8PCmoN9aaq30gDh27Xc0jk=" crossorigin="anonymous"></script>

    <script src="/js/activar-items-navbar.js"></script>
    <script src="/js/graficoTurno.js"></script>
    <script src="/js/spinners.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/logout-script.js"></script>
    <script src="/js/visualizar-turnos-matriculacion-home.js"></script>


    <script src="../node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../node_modules/echarts/dist/echarts.min.js"></script>



    <style>
        .table thead th {
            background-color: #f3f4f8;
        }
    </style>


</head>

<body>
    <div class="page-wrapper" id="main-wrapper" data-layout="vertical" data-sidebartype="full"
        data-sidebar-position="fixed" data-header-position="fixed">


        <!-- Inicio de barra de navegación -->
        <%- include('body/navbar') %>
            <!-- Fin de barra de navegación -->
            <!--  Contendio principal -->
            <div class="body-wrapper">
                <!--  Encabezado de pagina -->
                <%- include('body/header') %>

                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="card border">
                                    <div class="card-body h-100 p-3">
                                        <h5 class="mt-1 text-start fw-semibold mb-1">HOY
                                        </h5>
                                        <p class="text-muted mb-2 text-start">Procesos</p>

                                        <div class="d-flex justify-content-between align-items-center"
                                            style="height: 146px;">

                                            <div class="d-flex flex-row p-2 border rounded">
                                                <div
                                                    class="d-flex align-items-center justify-content-center text-center">
                                                    <i class="ti ti-clipboard-list fs-11 text-dark-sb"></i>
                                                </div>
                                                <div class="align-items-center justify-content-center row p-3">
                                                    <h3 class="fw-bold mb-0 text-start text-secondary">
                                                        <%= tramitesIngresados %>
                                                    </h3>
                                                    <span class="text-muted small ">Trámites ingresados</span>
                                                </div>
                                            </div>

                                            <div class="d-flex flex-row p-2 border rounded">
                                                <div
                                                    class="d-flex align-items-center justify-content-center text-center">
                                                    <i class="ti ti-clipboard-check fs-11 text-dark-sb"></i>
                                                </div>
                                                <div class="align-items-center justify-content-center row p-3">
                                                    <h3 class="fw-bold mb-0 text-start  text-secondary">
                                                        <%= tramitesFinalizados %>
                                                    </h3>
                                                    <span class="text-muted small">Trámites finalizados</span>
                                                </div>
                                            </div>

                                            <div class="d-flex flex-row p-2 border rounded">
                                                <div
                                                    class="d-flex align-items-center justify-content-center text-center">
                                                    <i class="ti ti-car fs-11 text-dark-sb"></i>
                                                </div>
                                                <div class="align-items-center justify-content-center row p-3">
                                                    <h3 class="fw-bold mb-0 text-start  text-secondary">
                                                        <%= tramitesRTV %>
                                                    </h3>
                                                    <span class="text-muted small">Trámites de revisión técnica</span>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-2">
                                <div class="card border">
                                    <div class="card-body text-center position-relative p-3">
                                        <h5 class="mt-1 text-start fw-semibold mb-1">MATRICULACIÓN</h5>
                                        <p class="text-muted mb-2 text-start">Último Turno</p>

                                        <div class="position-relative mx-auto d-flex align-items-center justify-content-center"
                                            style="width: 146px; height: 146px;">
                                            <div id="graficoTurno" class="w-100 h-100"></div>

                                            <div class="position-absolute text-1100 fs-9 fw-bold text-black">
                                                <%= ultimoTurno %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-2">
                                <div class="card border">
                                    <div class="card-body text-center position-relative p-3">
                                        <h5 class="mt-1 text-start fw-semibold mb-1">REVISIÓN TÉCNICA
                                        </h5>
                                        <p class="text-muted mb-2 text-start">Último Turno</p>

                                        <div class="position-relative mx-auto d-flex align-items-center justify-content-center"
                                            style="width: 146px; height: 146px;">
                                            <div id="graficoTurnoRTV" class="w-100 h-100"></div>

                                            <div class="position-absolute text-1100 fs-9 fw-bold text-black">
                                                <%= ultimoTurnoRTV %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h5 class="mt-3 text-start fw-semibold mb-1 d-none">REQUISITOS</h5>

                        <div class="row d-none">
                            <div class="col-lg-2">
                                <div class="">
                                    <div class="card-body text-center position-relative p-3">
                                        <p class="text-muted mb-2 text-start">Emisión del documento anual de
                                            circulación</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-6 mb-4">
                                <div class="card border-0 rounded-4 h-100 position-relative" id="cardTramite">

                                    <button id="btnCopiarImagen"
                                        class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 border"
                                        title="Copiar imagen">
                                        <i class="ti ti-copy text-primary fs-6"></i>
                                    </button>

                                    <div class="card-body p-4 text-start pb-2">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                                                style="width: 40px; height: 40px;">
                                                <i class="ti ti-file-description text-white fs-5"></i>
                                            </div>
                                            <h5 class="fw-bold text-black mb-0">Emisión del documento anual de
                                                circulación</h5>
                                        </div>
                                        <div class="border-start border-3 border-primary ps-3">
                                            <p class="fw-semibold text-black mb-2">Requisitos:</p>
                                            <ul class="list-unstyled mb-0 text-muted small">
                                                <li class="mb-1">• Matrícula vigente (original + 2 copias) o Certificado
                                                    Único Vehicular</li>
                                                <li class="mb-1">• Copia de la última revisión anual</li>
                                                <li class="mb-1">• Propietario (persona natural): copia de cédula</li>
                                                <li class="mb-1">• Propietario (empresa, institución): RUC, nombramiento
                                                    y cédula del representante
                                                    legal</li>
                                                <li class="mb-1">• Certificado de no adeudar EMMSZACH E.P.</li>
                                                <li class="mb-1">• Comprobantes de pago: rodaje, no adeudar, RTV,
                                                    sticker u otros</li>
                                                <li class="mb-1">• Comprobante de pago de matrícula (original + copia)
                                                </li>
                                                <li class="mb-1">• No tener citaciones pendientes (vehículo y
                                                    propietario)</li>
                                                <li class="mb-1">• Si lo realiza un tercero: autorización simple o poder
                                                    especial</li>
                                            </ul>
                                        </div>

                                        <div class="mt-3 border-start border-3 border-warning ps-3">
                                            <p class="fw-semibold text-black mb-2">Validaciones:</p>
                                            <ul class="list-unstyled mb-0 text-muted small">
                                                <li class="mb-1">• No tener citaciones pendientes de pago (vehículo y
                                                    propietario)</li>
                                            </ul>
                                        </div>

                                    </div>

                                    <!-- Footer -->
                                    <div
                                        class="card-footer bg-light text-dark text-center border-top-0 py-2 rounded-bottom-4">
                                        <span class="fw-semibold text-uppercase">Vehículo Particular</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-6 mb-4">
                                <div class="card border-0 rounded-4 h-100 position-relative" id="cardTramite">

                                    <button id="btnCopiarImagen"
                                        class="btn btn-light btn-sm position-absolute top-0 end-0 m-2 border"
                                        title="Copiar imagen">
                                        <i class="ti ti-copy text-primary fs-6"></i>
                                    </button>

                                    <div class="card-body p-4 text-start pb-2">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                                                style="width: 40px; height: 40px;">
                                                <i class="ti ti-file-description text-white fs-5"></i>
                                            </div>
                                            <h5 class="fw-bold text-black mb-0">Emisión del documento anual de
                                                circulación</h5>
                                        </div>
                                        <div class="border-start border-3 border-primary ps-3">
                                            <p class="fw-semibold text-black mb-2">Requisitos:</p>
                                            <ul class="list-unstyled mb-0 text-muted small">
                                                <li class="mb-1">• Matrícula vigente (original + 2 copias) o Certificado
                                                    Único Vehicular</li>
                                                <li class="mb-1">• Copia de la última revisión anual</li>
                                                <li class="mb-1">• Propietario (persona natural): copia de cédula</li>
                                                <li class="mb-1">• Propietario (empresa, institución): RUC, nombramiento
                                                    y cédula del representante
                                                    legal</li>
                                                <li class="mb-1">• Certificado de no adeudar EMMSZACH E.P.</li>
                                                <li class="mb-1">• Comprobantes de pago: rodaje, no adeudar, RTV,
                                                    sticker u otros</li>
                                                <li class="mb-1">• Comprobante de pago de matrícula (original + copia)
                                                </li>
                                                <li class="mb-1">• No tener citaciones pendientes (vehículo y
                                                    propietario)</li>
                                                <li class="mb-1">• Si lo realiza un tercero: autorización simple o poder
                                                    especial</li>
                                            </ul>
                                        </div>

                                        <div class="mt-3 border-start border-3 border-warning ps-3">
                                            <p class="fw-semibold text-black mb-2">Validaciones:</p>
                                            <ul class="list-unstyled mb-0 text-muted small">
                                                <li class="mb-1">• No tener citaciones pendientes de pago (vehículo y
                                                    propietario)</li>
                                            </ul>
                                        </div>

                                    </div>

                                    <div
                                        class="card-footer bg-warning text-dark text-center border-top-0 py-2 rounded-bottom-4">
                                        <span class="fw-semibold text-uppercase">Vehículo Público</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Librería html2canvas -->
                            <script
                                src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

                            <!-- Script para copiar imagen -->
                            <script>
                                document.getElementById("btnCopiarImagen").addEventListener("click", async () => {
                                    const card = document.getElementById("cardTramite");

                                    const canvas = await html2canvas(card, {
                                        backgroundColor: "#ffffff",
                                        scale: 2
                                    });

                                    canvas.toBlob(async (blob) => {
                                        try {
                                            await navigator.clipboard.write([
                                                new ClipboardItem({ "image/png": blob })
                                            ]);
                                            alert("Imagen copiada");
                                        } catch (err) {
                                            console.error("Error al copiar la imagen:", err);
                                            alert("No se pudo copiar la imagen");
                                        }
                                    });

                                });
                            </script>



                        </div>

                        <div class="card card-body">
                            <div class="d-sm-flex d-block align-items-center justify-content-between mb-9">
                                <div class="mb-3 mb-sm-0">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item">
                                            <a class="text-decoration-none text-black" href="/">Agenda</a>
                                        </li>
                                        <li class="breadcrumb-item text-muted" aria-current="page">
                                            <%= currentDaySimple %>
                                        </li>
                                    </ol>
                                </div>
                                <div style="width: 20%;">
                                    <input type="text" name="" class="form-control-disable text-center" id=""
                                        placeholder="">
                                </div>
                            </div>


                            <nav>
                                <div class="nav nav-tabs align-items-center justify-content-center" id="nav-tab"
                                    role="tablist">
                                    <button class="nav-link active" id="nav-home-tab" data-bs-toggle="tab"
                                        data-bs-target="#nav-home" type="button" role="tab" aria-controls="nav-home"
                                        aria-selected="true">Hoy
                                        <span id="TraPersonalHoy" class="ms-1"></span>
                                    </button>
                                    <button class="nav-link" id="nav-empresa-tab" data-bs-toggle="tab"
                                        data-bs-target="#nav-empresa" type="button" role="tab"
                                        aria-controls="nav-empresa" aria-selected="false">Pendientes (Empresa)
                                        <span id="TraGeneral" class="ms-1"></span>
                                    </button>
                                </div>
                            </nav>

                            <div class="tab-content border-top py-4 px-0" id="nav-tabContent">

                                <div class="tab-pane fade animated fadeInUp show active" id="nav-home" role="tabpanel"
                                    aria-labelledby="nav-home-tab">
                                    <div class="table-responsive2">
                                        <table class="table table-bordered">
                                            <thead id="thead-tramites-hoy">
                                                <tr class="text-black-font">
                                                    <th class="text-center align-middle px-2 py-2">N°</th>
                                                    <th class="text-center align-middle px-2 py-2">TRÁMITE</th>
                                                    <th class="text-center align-middle px-2 py-2">PLACA</th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-12">TIPO
                                                        DE TRAMITE</th>
                                                    <th class="text-center align-middle px-2 py-2">FECHA DE INGRESO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-4 text-wrap">
                                                        TIEMPO EN ESPERA</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        TURNO</th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-4">
                                                        ESTADO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        USUARIO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        USUARIO ASIGNADO</th>
                                                    <th class="text-center align-middle px-2 py-2">ACCIÓN</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tbody-tramites"></tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="tab-pane fade animated fadeInUp" id="nav-empresa" role="tabpanel"
                                    aria-labelledby="nav-empresa-tab">
                                    <div class="table-responsive2">
                                        <table class="table table-bordered">
                                            <thead id="thead-tramites-empresa">
                                                <tr class="text-black-font">
                                                    <th class="text-center align-middle px-2 py-2">N°</th>
                                                    <th class="text-center align-middle px-2 py-2">TRÁMITE</th>
                                                    <th class="text-center align-middle px-2 py-2">PLACA</th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-12">TIPO
                                                        DE TRAMITE</th>
                                                    <th class="text-center align-middle px-2 py-2">FECHA DE INGRESO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-4 text-wrap">
                                                        TIEMPO EN ESPERA</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        TURNO</th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-4">
                                                        ESTADO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        USUARIO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        USUARIO ASIGNADO</th>
                                                    <th class="text-center align-middle px-2 py-2">ACCIÓN</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tbody-tramitesEmpresa"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                        </div>


                    </div>



                    <div id="spinner-wrapper" class="spinner-wrapper">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading..</span>
                        </div>
                    </div>

                     <div id="alert-container"></div>
            </div>
</body>

</html>