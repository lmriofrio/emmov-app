<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <title>Turnos web</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.46.0/tabler-icons.min.css">
    <link rel="stylesheet" href="../../public/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.js"
        integrity="sha256-H+K7U5CnXl1h5ywQfKtSj8PCmoN9aaq30gDh27Xc0jk=" crossorigin="anonymous"></script>

    <script src="/js/buscar-vehiculo.js"></script>
    <script src="/js/activar-items-navbar.js"></script>
    <script src="/js/spinners.js"></script>

    <script src="/js/main.js"></script>

    <script src="../node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    <style>
        .table thead th {
            background-color: #f3f4f8;
        }

        .body-wrapper2 {
            margin: 70px;
            transition: .2s ease-in;
        }
        @media (max-width: 768px) {
            .body-wrapper2 {
                margin: 5px;
            }
        }
    </style>


</head>

<body>

    <div class="page-wrapper" id="main-wrapper" data-theme="blue_theme" data-layout="vertical" data-sidebartype="full"
        data-sidebar-position="fixed" data-header-position="fixed">
        <!-- Inicio de barra de navegación -->

        <!-- Fin de barra de navegación -->
        <!--  Contendio principal -->
        <div class="body-wrapper2">
            <!--  Encabezado de pagina -->

            <!--  Fin de encabezado de pagina  -->
            <div class="container-fluid p-0">
                <div class="widget-content searchable-container list">
                    <div class="card card-body h-100 p-2">
                        <div class="row align-items-center justify-content-center p-2">
                            <div class=" d-flex justify-content-center align-items-center">
                                <div
                                    class="col-md-12 justify-content-center align-items-center  flex-wrap align-items-center mb-2">
                                    <a href="/" class="d-flex align-items-center gap-2 rounded logo-img">
                                        <div class="rounded d-flex justify-content-center align-items-center"
                                            style="background: white; width: 45px; height: 45px;">
                                            <img src="/images/favicon.ico" class="rounded-circle" width="30"
                                                height="34">
                                        </div>
                                        <div
                                            style="white-space: nowrap; text-overflow: ellipsis; max-width: 170px; overflow: hidden;">
                                            <h2 class="mb-1 fw-semibold text-black">
                                                emmov
                                            </h2>
                                        </div>

                                    </a>
                                </div>
                            </div>

                            <div class="d-flex pb-4 justify-content-center align-items-center">
                                <div
                                    class="col-md-12 justify-content-center align-items-center  flex-wrap align-items-center mb-2">
                                    <h2
                                        class="fw-normal mb-0 justify-content-center align-items-center text-center fw-semibold">
                                        Generación de turnos web
                                    </h2>
                                </div>
                            </div>

                            <div class="row">

                                <div class="col-12 col-md-6 align-items-center justify-content-center p-2">
                                    <div class="py-3 px-3 border rounded">
                                        <h5 class="card-title fw-bold text-primary">Pasos para Agendar un Turno de
                                            Revisión</h5>
                                        <ol class="card-text">
                                            <li>Selecciona el tipo de trámite que deseas realizar.</li>
                                            <li>Ingresa la información del vehículo, como la placa y el tipo de
                                                transporte.</li>
                                            <li>Verifica los datos ingresados y confirma la solicitud.</li>
                                            <li>Elige la fecha y hora disponible para la revisión técnica.</li>
                                            <li>Recibe la confirmación del turno y guarda el comprobante.</li>
                                        </ol>
                                    </div>

                                </div>

                                <div class="col-12 col-md-6">
                                    <div class="form-group col">
                                        <label for="tipoTramite"
                                            class="col-sm-12 col-form-label fs-4 fw-semibold">Selecciona el tipo de trámite a realizar:</label>
                                        <div class="col-sm-12">
                                            <select class="form-select fw-normal bg-white" name="tipo_tramite"
                                                id="tipo_tramite" aria-label="Default select example" required>
                                                <option selected></option>
                                                <% tiposTramites.forEach(tipo=> { %>
                                                    <option value="<%= tipo.tipo_tramite %>">
                                                        <%= tipo.tipo_tramite %>
                                                    </option>
                                                    <% }); %>
                                            </select>
                                            <div class="invalid-feedback">
                                                Por favor, selecciona el tipo de trámite.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-12" id="mensaje-procesosRTV">
                                            <div
                                                class="p-3 text-black alert-dismissible fade show d-flex align-items-center gap-2">
                                                <i class="ti ti-exclamation-circle text-orange fs-5"></i>
                                                <span class="font-medium">
                                                    Verifica que los procesos para este tipo de trámite se encuentren
                                                    seleccionados.
                                                </span>
                                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                                    aria-label="Cerrar"></button>
                                            </div>
                                        </div>

                                    </div>


                                    <div class="row">
                                        <div class="col-12 col-md-6">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Placa:</label>
                                            <div class="col-sm-12">
                                                <div class="input-group">
                                                    <input type="text" name="placa" class="form-control text-uppercase"
                                                        placeholder="" aria-label="Recipient's username"
                                                        aria-describedby="basic-addon2" autocomplete="off">
                                                    <button class="btn btn-search text-white font-medium px-3"
                                                        type="button" id="buscarVehiculo_ServiciosWeb">
                                                        <i class="ti ti-search fs-4"></i>
                                                    </button>
                                                </div>
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                            </div>
                                        </div>
                                    </div>


                                    <div class="row">

                                        <div class="col-12 col-md-6">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Clase
                                                de transporte:</label>
                                            <div class="col-sm-12">
                                                <select class="form-select" name="clase_transporte"
                                                    id="clase_transporte"
                                                    required="">
                                                    <option selected=""></option>
                                                    <option value="COMERCIAL">COMERCIAL</option>
                                                    <option value="PARTICULAR">PARTICULAR</option>
                                                    <option value="PUBLICO">PUBLICO</option>
                                                    <option value="ESTATAL">ESTATAL</option>
                                                    <option value="MUNICIPAL">MUNICIPAL</option>
                                                </select>
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Tipo
                                                de vehículo:</label>
                                            <div class="col-sm-12">
                                                <select class="form-select" name="clase_vehiculo_tipo"
                                                    id="clase_vehiculo_tipo"
                                                    required="">
                                                    <option selected=""></option>
                                                    <option value="VEHICULO">VEHICULO</option>
                                                    <option value="MOTOCICLETA">MOTOCICLETA</option>
                                                </select>
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-12 col-md-4">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Tipo
                                                de peso:</label>
                                            <div class="col-sm-12">
                                                <select class="form-select" name="tipo_peso" id="tipo_peso" required="">
                                                    <option selected=""></option>
                                                    <option value="LIVIANO (<= 3,5 T)">
                                                        LIVIANO (&lt;= 3,5 T)</option>
                                                    <option value="PESADO (> 3,5 T)">
                                                        PESADO
                                                        (&gt; 3,5 T)</option>
                                                </select>
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                            </div>
                                            <small class="text-muted">Selecciona el tipo de peso</small>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Avalúo:</label>
                                            <div class="col-sm-12">
                                                <input type="number" class="form-control" autocomplete="off"
                                                    name="celular_usuario" id="celular_usuario" required=""
                                                    maxlength="10">
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                            </div>
                                            <small class="text-muted">Verifica el valor en el comprobante de pago de matrícula</small>
                                        </div>
                                        <div class="col-12 col-md-4">
                                            <label for="tipoTramite"
                                                class="col-sm-12 col-form-label fs-4 fw-semibold">Año de última revisión:</label>
                                            <div class="col-sm-12">
                                                <select class="form-select" name="anio" id="anio" required>
                                                    <option selected disabled></option>
                                                    <option value="2017">2017</option>
                                                    <option value="2018">2018</option>
                                                    <option value="2019">2019</option>
                                                    <option value="2020">2020</option>
                                                    <option value="2021">2021</option>
                                                    <option value="2022">2022</option>
                                                    <option value="2023">2023</option>
                                                    <option value="2024">2024</option>
                                                </select>
                                                <div class="invalid-feedback">
                                                    Por favor, selecciona el tipo de trámite.
                                                </div>
                                                <small class="text-muted">Seleccion el útlimo año de revisíon</small>
                                            </div>
                                        </div>
                                    </div>
                                    <hr>
                                </div>


                            </div>

                           

                            


                            <div class="row justify-content-end align-items-right pb-4">
                                <div
                                    class="col-12 col-md-2 d-flex justify-content-center align-items-center pt-3">
                                    <button id="BtnContinuarPaso1"
                                        class="btn btn-primary btn-rounded fw-semibold px-4 py-2 shadow-btn d-none w-100 w-md-auto">
                                        Continuar
                                    </button>
                                </div>
                            </div>




                            <script>
                                document.getElementById("tipo_tramite").addEventListener("change", function () {
                                    let boton = document.getElementById("BtnContinuarPaso1");
                                    boton.classList.toggle("d-none", this.value === "");
                                });

                                document.getElementById("BtnContinuarPaso1").addEventListener("click", function () {
                                    document.getElementById("camposAdicionales").classList.remove("d-none");
                                });
                            </script>





                            <div class="d-none d-flex col-7 row align-items-center justify-content-center" id="content">
                                <div class="pt-4 col-12 d-flex align-items-center justify-content-center">
                                    <br>
                                    <div class="table-responsive2 col-12">
                                        <table class="table table-bordered mb-0">
                                            <thead id="thead-tramites">
                                                <tr class="text-dark">
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-2">N°
                                                    </th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-3">PLACA
                                                    </th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-3">
                                                        SERVICIO
                                                    </th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-3 text-wrap">
                                                        TIPO
                                                        DE
                                                        VEHICULO</th>
                                                    <th
                                                        class="text-center align-middle px-2 py-2 text-overflow-2 text-wrap">
                                                        CANTIDAD</th>
                                                    <th class="text-center align-middle px-2 py-2 text-overflow-3">
                                                        ESTADO</th>
                                                </tr>

                                            </thead>
                                            <tbody id="tbody-tramites">
                                        </table>
                                    </div>
                                </div>

                                <div class="mt-3 d-flex justify-content-center align-items-center col-12">
                                    <div
                                        class="col-md-12 justify-content-center align-items-center  flex-wrap align-items-center mb-2">
                                        <h6 class="fw-normal mb-0 justify-content-center align-items-center text-end fw-normal"
                                            id="numeroRegistros">

                                        </h6>
                                    </div>
                                </div>

                                <div class="mt-2 d-flex justify-content-center align-items-center col-12">


                                    <div class="row">

                                        <div class=" ">
                                            <h5>
                                                <span class="fw-normal">Las placas</span>
                                                <span id="placaConsultada" name="placaConsultada"
                                                    class="fw-semibold"></span>
                                                <span class="fw-normal">ya se encuentran disponibles.</span>
                                            </h5>
                                        </div>

                                        <div class=" ">
                                            <p>Retira la placa metálica en las instalaciones de la Empresa Mancomunada
                                                de Movilidad Sustentable de Zamora Chinchipe E.P.</p>
                                        </div>

                                        <div class="pt-2 ">
                                            <h5 class="fw-semibold">Requisitos (propietario):</h5>
                                            <P class="p-0 m-0">- Copia de matrícula del vehículo</P>
                                            <p class="p-0 m-0">- Copia de cédula de identidad</p>
                                        </div>

                                        <div class="pt-2 ">
                                            <h5 class="fw-semibold">Requisitos (tercera persona):</h5>
                                            <P class="p-0 m-0">- Oficio dirigido al gerente de la empresa, autorizando
                                                el retiro de las placas metálicas.</P>
                                            <P class="p-0 m-0">- Copia de matrícula del vehículo</P>
                                            <p class="p-0 m-0">- Copia de cédula de identidad (propietario)</p>
                                            <p class="p-0 m-0">- Copia de cédula de identidad (tercera persona)</p>
                                        </div>


                                    </div>
                                </div>
                            </div>

                            <div class="d-none d-flex col-8 row align-items-center justify-content-center border rounded"
                                id="sinResultados">
                                <div class="pt-4 pb-4 col-12 d-flex align-items-center justify-content-center">
                                    <br>
                                    <h4>Sin registros</h4>
                                </div>
                            </div>





                        </div>
                    </div>
                </div>
            </div>


            <div id="spinner-wrapper" class="spinner-wrapper">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading..</span>
                </div>
            </div>

            <div id="alert-container"></div>



        </div>
    </div>

</body>

</html>