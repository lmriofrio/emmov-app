                                    <script>
                                        let currentDate = new Date();
                                        const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
                                        const turnosHorarios = ["08:00 AM", "09:00 AM", "10:00 AM", "11:00 AM", "12:00 PM", "02:00 PM", "03:00 PM", "04:00 PM", "05:00 PM"];

                                        function renderCalendar() {
                                            const year = currentDate.getFullYear(), month = currentDate.getMonth();
                                            document.getElementById("month-year").textContent = `${monthNames[month]} ${year}`;

                                            const firstDay = new Date(year, month, 1).getDay(), lastDate = new Date(year, month + 1, 0).getDate();
                                            let daysHTML = "", dayCount = 1;

                                            for (let i = 0; i < 6; i++) { // 6 filas máximo
                                                let row = '<div class="row text-center">';
                                                for (let j = 0; j < 7; j++) {
                                                    if ((i === 0 && j < firstDay) || dayCount > lastDate) {
                                                        row += `<div class="col text-muted"></div>`;
                                                    } else {
                                                        row += `<div class="col" onclick="mostrarTurnos(${dayCount})">${dayCount++}</div>`;
                                                    }
                                                }
                                                daysHTML += row + '</div>';
                                                if (dayCount > lastDate) break;
                                            }

                                            document.getElementById("calendar-days").innerHTML = daysHTML;
                                        }

                                        function changeMonth(step) {
                                            currentDate.setMonth(currentDate.getMonth() + step);
                                            renderCalendar();
                                        }

                                        function mostrarTurnos(dia) {
                                            document.getElementById("turnos-container").style.display = "block";
                                            const fechaSeleccionada = `${dia} de ${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`;
                                            document.getElementById("selected-date").textContent = fechaSeleccionada;

                                            let turnosHTML = "";
                                            turnosHorarios.forEach((hora, index) => {
                                                let disponible = Math.random() > 0.5;
                                                turnosHTML += `
                                                <div class="turno ${disponible ? 'disponible' : 'no-disponible'}">
                                                    <span><i class="ti ti-calendar-plus"></i> ${hora}</span>
                                                    <button class="btn btn-sm ${disponible ? 'btn-success' : 'btn-secondary'}" ${disponible ? '' : 'disabled'}>
                                                        ${disponible ? 'Agendar' : 'Ocupado'}
                                                    </button>
                                                </div>`;
                                            });

                                            document.getElementById("turnos-list").innerHTML = turnosHTML;
                                        }

                                        document.addEventListener("DOMContentLoaded", renderCalendar);
                                    </script>




