<!doctype html>
<html lang="es" data-bs-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <title>Vista de turnos en atención</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.46.0/tabler-icons.min.css">
    <link rel="stylesheet" href="../../public/css/style.css">
    <script src="https://code.jquery.com/jquery-3.6.0.js"
        integrity="sha256-H+K7U5CnXl1h5ywQfKtSj8PCmoN9aaq30gDh27Xc0jk=" crossorigin="anonymous"></script>

    <script src="/js/visualizar-turnos-matriculacion.js"></script>
    <script src="/js/main.js"></script>

    <script src="../node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    <style>
        @media (max-width: 768px) {
            .body-wrapper2 {
                margin: 5px;
            }
        }
    </style>


</head>

<body>

    <div class="page-wrapper" id="main-wrapper" data-layout="vertical" data-sidebartype="full"
        data-sidebar-position="fixed" data-header-position="fixed">

        <div class="body-wrapper2 m-1">
            <div class="container-fluid p-4">
                <div class="widget-content searchable-container list">
                    <div class="card card-body h-100 p-2">

                        <!-- LOGO -->
                        <div class=" d-flex justify-content-center align-items-center m-2">
                            <div
                                class="col-md-12 justify-content-center align-items-center  flex-wrap align-items-center mb-2">
                                <a href="/" class="d-flex align-items-center gap-2 rounded logo-img">
                                    <div class="rounded d-flex justify-content-center align-items-center"
                                        style="background: white; width: 45px; height: 45px;">
                                        <img src="/images/favicon.ico" class="rounded-circle" width="30" height="34">
                                    </div>
                                    <div
                                        style="white-space: nowrap; text-overflow: ellipsis; max-width: 170px; overflow: hidden;">
                                        <h2 class="mb-1 fw-semibold text-muted">
                                            emmov
                                        </h2>
                                    </div>

                                </a>
                            </div>
                        </div>

                        <!-- TITULO -->
                        <h2 class="text-center fw-normal my-2">
                            TURNOS EN ATENCIÓN
                        </h2>


                        <div class="mt-2 m-2">
                            <div class="row">

                                <div class="col-lg-8 col-md-8 col-12 fs-13">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover no-opacity">
                                            <thead id="thead-tramites">
                                                <tr class="text-black-font">
                                                    <th class="text-center">N°</th>
                                                    <th class="text-center">FUNCIONARIO</th>
                                                    <th class="text-center">PLACA</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tbody-tramites"></tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="col-lg-4 col-md-4 col-12 p-0">
                                    <div id="sliderTurnos" class="carousel slide" data-bs-ride="carousel"
                                        data-bs-interval="5000">
                                        <div class="carousel-inner">


                                            <div class="carousel-item">
                                                <img src="/images/Zamo.webp" class="d-block w-100" alt="Imagen 4">
                                            </div>

                                            <div class="carousel-item active">
                                                <img src="/images/autorizado.jpeg" class="d-block w-100" alt="Imagen 1">
                                            </div>

                                            <div class="carousel-item">
                                                <img src="/images/Marzo1.webp" class="d-block w-100" alt="Imagen 5">
                                            </div>

                                            <div class="carousel-item">
                                                <img src="/images/precios.jpg" class="d-block w-100" alt="Imagen 2">
                                            </div>

                                            <div class="carousel-item">
                                                <img src="/images/Marzo2.webp" class="d-block w-100" alt="Imagen 6">
                                            </div>

                                        </div>
                                    </div>
                                </div>


                            </div>
                        </div>

                        <div class="px-3 py-1 row align-items-center">
                            <label for="switchTema" class="col-1 col-md-1 form-label mb-0 text-muted">
                                Tema
                            </label>
                            <div class="col-8 col-md-9">
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" id="switchTema">
                                </div>
                            </div>
                        </div>

                        <div class="px-3 py-1 pb-3 row align-items-center">
                            <label for="switchSonido" class="col-1 col-md-1 form-label mb-0 text-muted">
                                Sonido
                            </label>
                            <div class="col-8 col-md-9">
                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" id="switchSonido">
                                </div>
                            </div>
                        </div>




                    </div>
                </div>
            </div>
        </div>
    </div>

    <audio id="sonidoTurno" src="/sounds/turno.mp3" preload="auto"></audio>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const htmlTag = document.documentElement;
            const switchTema = document.getElementById("switchTema");

            if (!switchTema) return;

            const tema = localStorage.getItem("preferenciaTema") || "light";
            htmlTag.setAttribute("data-bs-theme", tema);
            switchTema.checked = (tema === "dark");

            switchTema.addEventListener("change", () => {
                const nuevo = switchTema.checked ? "dark" : "light";
                htmlTag.setAttribute("data-bs-theme", nuevo);
                localStorage.setItem("preferenciaTema", nuevo);
            });
        });
    </script>

</body>


</html>